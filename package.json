{
  "name": "arivonriyam",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @arivonriyam/server dev",
    "dev:client": "pnpm --filter @arivonriyam/client dev",
    "dev": "pnpm run dev:server & pnpm run dev:client",
    "build:client": "pnpm --filter @arivonriyam/client build",
    "build": "pnpm run build:client",
    "start": "pnpm --filter @arivonriyam/server start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter @arivonriyam/server test",
    "test:smoke": "pnpm --filter @arivonriyam/server test"
  },
  "keywords": [],
  "author": "Balasubramanian",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte-eslint-parser": "^1.6.0",
    "typescript-eslint": "^8.58.2"
  }
