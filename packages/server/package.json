{
  "name": "@arivonriyam/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "rag:install": "python3 -m pip install -r python/requirements.txt",
    "rag:ingest": "python3 python/ingest.py --data-root ./data",
    "rag:retrieve": "python3 python/retriever.py --data-root ./data --grade 3 --subject maths --query \"What is addition?\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Balasubramanian",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "tsx": "^4.21.0"
  }
}
